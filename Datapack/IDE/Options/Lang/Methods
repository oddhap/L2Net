### Methods, DO NOT EDIT ###
.type=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.TYPE</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br> Returns a global with the variable type.<br><U><B>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr <br>PRINT_TEXT "<&myStr.TYPE&>" <br>Will print: &ldquo;STRING&rdquo; <br></i></font></BODY></HTML>
.classname=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.CLASSNAME</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br> Returns a string with the variable type.<br><br><U><B>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr <br>PRINT_TEXT "<&myStr.CLASSNAME&>" <br><br>Will print: &ldquo;STRING&rdquo; <br></i></font></BODY></HTML>
.clone=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.CLONE</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br> Returns an exact copy of the variable.<br><br><U><B>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr <br>DEFINE STRING anotherStr<br>anotherStr = myStr.CLONE <br><br>The String 'anotherStr' will be equal to 'myStr'.</i></font></BODY></HTML>
.get_hex=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.GET_HEX</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br> Returns the string version of the hex value of this variable. (8 bytes)<br><br><U><B>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE INT myInt <br>myInt = ONE <br>DEFINE STRING myStr<br>myStr = myInt.GET_HEX <br><br>The String 'myStr' will equal '01 00 00 00 00 00 00 00'.</i></font></BODY></HTML>
.get_hex32=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.GET_HEX32</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br> Returns the string version of the hex value of this variable cast to a 32 bit value. (4 bytes)<br><br><U><B>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE INT myInt <br>myInt = ONE <br>DEFINE STRING myStr<br>myStr = myInt.GET_HEX32 <br><br>The String 'myStr' will equal '01 00 00 00'.</i></font></BODY></HTML>
.length=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.LENGTH</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br> Returns an int containing the number of elements in the object.<br><br><U><B>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "wasap"<br>PRINT_TEXT "<&myStr.LENGTH&>"<br><br>Will print: '5'</i></font></BODY></HTML>
.count=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.COUNT</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br> Returns an int containing the number of elements in the object.<br><br><U><B>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "wasap"<br>PRINT_TEXT "<&myStr.COUNT&>"<br><br>Will print: '5'</i></font></BODY></HTML>
.reverse=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.REVERSE</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Reverses the order of the elements in the object.<br><br><U><B></BODY></HTML>
.to_upper=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.TO_UPPER</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the string where all characters have been converted to uppercase using the local system's locale uppercase rules.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "wasap"<br>PRINT_TEXT "<&myStr.TO_UPPER&>"<br><br>Will print: 'WASAP'</i></font></BODY></HTML>
.to_upper_invariant=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.TO_UPPER_INVARIANT</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the string where all characters have been converted to uppercase using the invariant culture rules (English).<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "wasap"<br>PRINT_TEXT "<&myStr.TO_UPPER_INVARIANT&>"<br><br>Will print: 'WASAP'</i></font></BODY></HTML>
.to_lower=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.TO_LOWER</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the string where all characters have been converted to lowercase using the local system's locale uppercase rules.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "WASAP"<br>PRINT_TEXT "<&myStr.TO_LOWER&>"<br><br>Will print: 'wasap'</i></font></BODY></HTML>
.to_lower_invariant=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.TO_LOWER_INVARIANT</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the string where all characters have been converted to lowercase using the invariant culture rules (English).<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "WASAP"<br>PRINT_TEXT "<&myStr.TO_LOWER_INVARIANT&>"<br><br>Will print: 'wasap'</i></font></BODY></HTML>
.trim=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.TRIM</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the string where all whitespace characters have been removed from the the start and end of the string.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "  aeiou    "<BR> myStr.TRIM<br><br>  The string myStr will equal 'aeiou'</i></font></BODY></HTML>
.lastindexof=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.LASTINDEXOF [indexString]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the int location of the last index of indexString.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "wasap"<br> DEFINE INT i<br> i = myStr.LASTINDEXOF #$a  <BR><BR>The int i will equal '3'</i></font></BODY></HTML>
.indexof=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.INDEXOF [indexString]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the int location of the first index of indexString.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "wasap" <br>DEFINE INT i<br> i = myStr.INDEXOF #$a  <br><br>The int i will equal '1'</i></font></BODY></HTML>
.trimend=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.TRIMEND [removeString]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the string where the string 'removeString' has been removed from the end.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "wasap"<br> PRINT_TEXT "<& myStr.TRIMEND #$ap &>" <br><br> Will print: 'was'</i></font></BODY></HTML>
.trimstart=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.TRIMSTART [removeString]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the string where the string 'removeString' has been removed from the start.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "wasap"<br> PRINT_TEXT "<& myStr.TRIMSTART #$was &>" <br><br> Will print: 'ap'</i></font></BODY></HTML>
.contains=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.CONTAINS [str]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the global TRUE or FALSE depending if the string 'str' was contained in the string.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "wasap"<br> IF myStr.CONTAINS #$ap<br>PRINT_TEXT "true"<br> ENDIF</i></font></BODY></HTML>
.substring=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.SUBSTRING [startIndex] [endIndex]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the string starting from the integer 'startIndex' to the integer 'endIndex'.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "wasap" <br>PRINT_TEXT "<&myStr.SUBSTRING ZERO THREE&>"<br><br> Will Print: 'was'</i></font></BODY></HTML>
.replace=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.REPLACE [initialString] [replaceString]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the string where the string 'initialString', contained in the string, was replaced with the string 'replaceString'.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "wasap"<br> PRINT_TEXT "<&myStr.REPLACE #$ap #$abi&>"<br><br> Will Print: 'wasabi'</i></font></BODY></HTML>
.startswith=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.STARTSWITH [Str]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the global TRUE or FALSE depending if the string 'Str' was at the start of the string.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "wasap"<br> PRINT_TEXT "<&myStr.STARTSWITH #$was&>" <br><br>Will Print: 'TRUE'</i></font></BODY></HTML>
.endswith=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.ENDSWITH [Str]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the global TRUE or FALSE depending if the string 'Str' was at the end of the string.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE STRING myStr "wasap"<br> PRINT_TEXT "<&myStr.ENDSWITH #$ap&>" <br><br>Will Print: 'TRUE'</i></font></BODY></HTML>
.flush=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.FLUSH</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Forces the file to commit any cached writes to disk.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE FILEWRITER myFile "asd.txt"<br> myFile.WRITE "#$Hi There"<br> myFile.FLUSH<br> myFile.CLOSE</i></font></BODY></HTML>
.close= <HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.CLOSE</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Close the opened file. No further data may be written.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE FILEWRITER myFile "asd.txt"<br> myFile.WRITE "#$Hi There"<br> myFile.FLUSH<br> myFile.CLOSE</i></font></BODY></HTML>
.write=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.WRITE [OBJECT]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Writes the value of variable 'Object' to the file.<br> <u><i>Important Note</u>:</i> 'Object must be an INT, a DOUBLE or a STRING.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE FILEWRITER myFile "asd.txt"<br> myFile.WRITE "#$Hi There"<br> myFile.FLUSH<br> myFile.CLOSE</i></font></BODY></HTML>
.read=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.WRITE [OBJECT]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Reads a line from the file which is then converted to the type of 'Object' and stored in 'Object'.<br> <u><i>Important Note</u>:</i> 'Object must be an INT, a DOUBLE or a STRING.<U><B></font></BODY></HTML>
.[int]=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.[int]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the element at index 'int'.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE ARRAYLIST myAl<br> myAl.ADD "#$Hello!" <br>PRINT_TEXT "<& myAl.ZERO &>"<br><br>  Will Print: 'Hello!'</i></font></BODY></HTML>
.add=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.ADD [addObject]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Puts 'addObject' at the end of the list.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE ARRAYLIST myAl<br> myAl.ADD "#$Hello!" <br>PRINT_TEXT "<& myAl.ZERO &>"<br><br>  Will Print: 'Hello!'</i></font></BODY></HTML>
.push=.add=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.PUSH [addObject]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Puts 'addObject' at the end of the list.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE ARRAYLIST myAl<br> myAl.PUSH "#$Hello!" <br>PRINT_TEXT "<& myAl.ZERO &>"<br><br>  Will Print: 'Hello!'</i></font></BODY></HTML>
.remove=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.REMOVE [int]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Removes the element at location 'int'. The data is shifted left accordingly.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE ARRAYLIST myAl<br> myAl.ADD "#$Hello!"<br> myAl.REMOVE ZERO</i></font></BODY></HTML>
.removeat=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.REMOVEAT [int]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Removes the element at location 'int'. The data is shifted left accordingly.<U><B><br>Example</U>:</B><br></B><i><FONT SIZE="2">DEFINE ARRAYLIST myAl<br> myAl.ADD "#$Hello!"<br> myAl.REMOVEAT ZERO</i></font></BODY></HTML>
.clear=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.CLEAR</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Removes all the elements of a list.<U><B></i></font></BODY></HTML>
.[string]=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.[String]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the element with key 'String'. Works for Sortedlists only.<U><B></i></font></BODY></HTML>
.get_key=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.GET_KEY [int]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the string key at index 'int'. Works for Sortedlists only.<U><B></i></font></BODY></HTML>
.contains_key=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.CONTAINS_KEY [String]</B></U></FONT></CENTER><BR><U><B>Description</U>:Returns the global TRUE or FALSE depending if the key 'String' exists. Works for Sortedlists only.</B><br><U><B></i></font></BODY></HTML>
.peek=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.PEEK</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the variable on the top of the stack/queue.<U><B></i></font></BODY></HTML>
.pop=.peek=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.PEEK</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Returns the variable on the top of the stack/queue and removes it.<U><B></i></font></BODY></HTML>
.trim_to_index=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.TRIM_TO_INDEX</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Resizes the bytebuffer to match the current cursor position. Use to trim extra length before sending.<U><B></i></font></BODY></HTML>
.reset_index=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.RESET_INDEX</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Resets the index for reading and writing to the start of the buffer (index = 0).<U><B></i></font></BODY></HTML>
.write_uint16=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.WRITE_UINT16 [Object]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the value of 'Object' to a 16 bit unsigned integer and writes it to the bytebuffer. The cursor is advanced by 2.<U><B></i></font></BODY></HTML>
.write_uint32=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.WRITE_UINT32 [Object]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the value of 'Object' to a 32 bit unsigned integer and writes it to the bytebuffer. The cursor is advanced by 4.<U><B></i></font></BODY></HTML>
.write_uint64=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.WRITE_UINT64 [Object]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the value of 'Object' to a 64 bit unsigned integer and writes it to the bytebuffer. The cursor is advanced by 8.<U><B></i></font></BODY></HTML>
.write_int16=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.WRITE_INT16 [Object]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the value of 'Object' to a 16 bit signed integer and writes it to the bytebuffer. The cursor is advanced by 2.<U><B></i></font></BODY></HTML>
.write_int32=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.WRITE_INT32 [Object]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the value of 'Object' to a 32 bit signed integer and writes it to the bytebuffer. The cursor is advanced by 4.<U><B></i></font></BODY></HTML>
.write_int64=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.WRITE_INT64 [Object]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the value of 'Object' to a 64 bit signed integer and writes it to the bytebuffer. The cursor is advanced by 8.<U><B></i></font></BODY></HTML>
.write_double=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.WRITE_DOUBLE [Object]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the value of 'Object' to a double precision floating point value and writes it to the bytebuffer. The cursor is advanced by 8.<U><B></i></font></BODY></HTML>
.write_byte=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.WRITE_BYTE [Object]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the value of 'Object' to a 8 bit unsigned integer and writes it to the bytebuffer. The cursor is advanced by 1.<U><B></i></font></BODY></HTML>
.write_string=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.WRITE_STRING [Object]</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the value of 'Object' to a unicode string and writes it to the bytebuffer. The cursor is advanced by length * 2 + 2.<U><B></i></font></BODY></HTML>
.read_uint16=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.READ_UINT16</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the next 2 bytes to a 16 bit unsigned integer and returns it. The cursor is advanced by 2.<U><B></i></font></BODY></HTML>
.read_uint32=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.READ_UINT32</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the next 4 bytes to a 32 bit unsigned integer and returns it. The cursor is advanced by 4.<U><B></i></font></BODY></HTML>
.read_uint64=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.READ_UINT64</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the next 8 bytes to a 64 bit unsigned integer and returns it. The cursor is advanced by 8.<U><B></i></font></BODY></HTML>
.read_int16=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.READ_INT16</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the next 2 bytes to a 16 bit signed integer and returns it. The cursor is advanced by 2.<U><B></i></font></BODY></HTML>
.read_int32=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.READ_INT32</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the next 4 bytes to a 32 bit signed integer and returns it. The cursor is advanced by 4.<U><B></i></font></BODY></HTML>
.read_int64=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.READ_INT64</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the next 8 bytes to a 64 bit signed integer and returns it. The cursor is advanced by 8.<U><B></i></font></BODY></HTML>
.read_double=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.READ_DOUBLE</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the next 8 bytes to a double precision floating point value and returns it. The cursor is advanced by 8.<U><B></i></font></BODY></HTML>
.read_byte=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.READ_BYTE</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Converts the next byte to an 8 bit unsigned integer and returns it. The cursor is advanced by 1.<U><B></i></font></BODY></HTML>
.read_string=<HTML><BODY><FONT FACE="Verdana, sans-serif"><CENTER><U><B><FONT  COLOR="#00ae00" SIZE=4>.READ_STRING</B></U></FONT></CENTER><BR><U><B>Description</U>:</B><br>Reads the next unicode string from the bytebuffer and returns it. Reading is stopped when 0x0000 is read. The cursor is advanced accordingly.<U><B></i></font></BODY></HTML>



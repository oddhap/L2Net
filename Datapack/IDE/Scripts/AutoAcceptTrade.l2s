SET_EVENT "<&SCRIPTEVENT_SYSTEMMESSAGE&>" "<&SYSTEM_CURRENTFILE&>" conftrade
SET_EVENT "<&SCRIPTEVENT_SERVERPACKET&>" "<&SYSTEM_CURRENTFILE&>" trade 112
FUNCTION trade
SLEEP 1000
INJECT "55 01 00 00 00"
RETURN VOID

FUNCTION conftrade
IF "MESSAGE.CONTAINS #$confirmed" == TRUE
INJECT "1C 01 00 00 00"
BREAK 1
ENDIF
RETURN VOID


